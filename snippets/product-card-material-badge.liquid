{%- comment -%}
  ----------------------------------------------------------------------------------------------------------------------
  PRODUCT CARD MATERIAL BADGE COMPONENT
  ----------------------------------------------------------------------------------------------------------------------

  Renders a single material badge in the top-left corner of the product card image based on the product tags.
  - If the product is tagged with "טבעוני" (or "vegan") -> green VEGAN badge with leaf icon.
  - If the product is tagged with "עור" (or "leather") -> brown LEATHER badge with hide icon.
  Both are mutually exclusive; vegan takes priority if both tags are accidentally present.

  ********************************************
  Supported variables
  ********************************************

  * product: the product to inspect for tags
{%- endcomment -%}

{%- liquid
  assign material_kind = ''

  for tag in product.tags
    assign tag_clean = tag | strip | downcase

    if tag_clean == 'טבעוני' or tag_clean == 'vegan'
      assign material_kind = 'vegan'
      break
    elsif tag_clean == 'עור' or tag_clean == 'leather'
      assign material_kind = 'leather'
    endif
  endfor
-%}

{%- if material_kind == 'vegan' -%}
  <span class="material-badge material-badge--vegan" aria-label="Vegan">
    <svg class="material-badge__icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M14.5 2.2c-.4 0-2.1.1-4.1.7C5.7 4.3 2.1 7.3 2.1 11.2c0 .9.2 1.6.5 2.2L1.5 14.6c-.2.2-.2.6 0 .8.2.2.6.2.8 0l1.1-1.1c.6.3 1.4.5 2.2.5 3.9 0 6.9-3.6 8.3-8.2.6-2 .7-3.7.7-4.1 0-.2-.1-.3-.1-.3zM5.6 13.6c-.5 0-1-.1-1.4-.3l5.7-5.7c.2-.2.2-.6 0-.8-.2-.2-.6-.2-.8 0l-5.7 5.7c-.2-.4-.3-.9-.3-1.4 0-3.4 3.2-6.1 7.5-7.4 1.4-.4 2.7-.6 3.4-.6-.1.7-.2 2-.6 3.4-1.3 4.4-4 7.5-7.4 7.5z" fill="currentColor"/>
    </svg>
    <span class="material-badge__text">VEGAN</span>
  </span>
{%- elsif material_kind == 'leather' -%}
  <span class="material-badge material-badge--leather" aria-label="Leather">
    <svg class="material-badge__icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M3 5c.6-1 1.6-1.5 2.5-1.5.7 0 1.2.3 1.7.6.3.2.5.4.8.4s.5-.2.8-.4c.5-.3 1-.6 1.7-.6.9 0 1.9.5 2.5 1.5.4.7.5 1.5.4 2.2-.1.5.1 1 .4 1.4.5.6.7 1.4.5 2.2-.3 1.2-1.4 2.1-2.6 2.4-1 .2-1.9 0-2.7-.4-.3-.2-.5-.3-.8-.3s-.5.1-.8.3c-.8.4-1.7.6-2.7.4C2.5 12.7 1.4 11.8 1.1 10.6c-.2-.8 0-1.6.5-2.2.3-.4.5-.9.4-1.4-.1-.7 0-1.5.4-2.2zm2.5-.3c-.5 0-1.1.3-1.5.9-.2.4-.3.8-.2 1.2.1.9-.2 1.7-.7 2.4-.2.3-.3.7-.2 1 .2.7.8 1.2 1.6 1.4.7.2 1.3 0 1.8-.2.5-.3.9-.4 1.4-.4s.9.1 1.4.4c.5.2 1.1.4 1.8.2.8-.2 1.4-.7 1.6-1.4.1-.3 0-.7-.2-1-.5-.7-.8-1.5-.7-2.4.1-.4 0-.8-.2-1.2-.4-.6-1-.9-1.5-.9-.4 0-.7.2-1.1.4-.4.2-.8.5-1.3.5s-.9-.3-1.3-.5c-.4-.2-.7-.4-1.1-.4z" fill="currentColor"/>
    </svg>
    <span class="material-badge__text">LEATHER</span>
  </span>
{%- endif -%}
